# data.ai (App Annie) Intelligence API key
# Obtain from your data.ai account dashboard
# https://www.data.ai
DATA_AI_API_KEY=your_data_ai_api_key_here

# Anthropic API key — required for the Morning Research Report
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# X.com (Twitter) API v2 Bearer Token — required for X.com posts
# Obtain from https://developer.twitter.com → Projects & Apps → your app → Keys and Tokens
# Free tier supports up to 10 results per search query
X_BEARER_TOKEN=your_x_bearer_token_here

# Truth Social requires no API key — public posts are accessible without authentication
